# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual env
.venv/
.pixi/

# Streamlit cache
.streamlit/

# Local runtime artifacts
logs/
backups/
# --- Runtime / generated files (ignore) ---
storage/*.db
storage/*.sqlite
storage/*.zip
storage/*.log
storage/tmp/
storage/archive/

outputs/*.pdf
outputs/*.xml
outputs/*.tmp
outputs/*.zip

# --- BUT keep code tracked ---
!outputs/__init__.py
!outputs/pdf.py
!outputs/finvoice.py

# If storage contains python modules, keep them tracked
!storage/**

# (and ensure python files are never ignored)
!storage/**/*.py
receipts/
data/

# Secrets
.env
.env.*

# Logs
*.log

# Frontend (Next.js)
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.env.local
frontend/.env.*.local

# OS / Editor
.DS_Store
.vscode/
Thumbs.db
